{
  "compilerOptions": {
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES6",
    "noImplicitAny": true,
    "noImplicitThis": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "importHelpers": true,
    "isolatedModules": true,
    "strict": true,
    "strictNullChecks": true,
    "rootDir": "src",
		"lib": ["DOM", "ES2019"],
    "paths": {
      "*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
