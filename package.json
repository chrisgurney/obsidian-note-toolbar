{
  "name": "obsidian-note-toolbar",
  "version": "1.34.11",
  "description": "Obsidian plugin that adds customizable toolbars to your notes.",
  "main": "main.js",
  "scripts": {
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "dev": "npm run prebuild && node esbuild.config.mjs",
    "lint": "npx eslint .",
    "prebuild": "node -p \"'export const PLUGIN_VERSION = ' + JSON.stringify(require('./package.json').version) + ';'\" > src/version.ts",
    "release": "node release.mjs",
    "stylelint": "npx stylelint '**/*.css'",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "keywords": [],
  "author": "Chris Gurney",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/sortablejs": "^1.15.8",
    "chokidar": "^5.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-obsidianmd": "latest",
    "obsidian": "latest",
    "stylelint": "^17.12.1",
    "stylelint-config-standard": "^40.0.0",
    "typedoc": "^0.28.14",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.64.0"
  },
  "dependencies": {
    "@codemirror/view": "6.38.6",
    "sortablejs": "^1.15.2"
  }
}
