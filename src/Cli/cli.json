{
    "categories": {
        "help": { 
            "heading": "Help" 
        },
        "items": { 
            "heading": "Items" 
        },
        "items-add": { 
            "heading": "Items (Adding)", 
            "docs": "Add items to toolbars." 
        },
        "items-copy": { 
            "heading": "Items (Copying + Moving)", 
            "docs": "Copy and move items to toolbars." 
        },
        "rules": {
            "heading": "Rules",
            "docs": "Display folder mappings"
        },
        "settings": {
            "heading": "Settings"
        },
        "toolbars": { 
            "heading": "Toolbars" 
        }
    },
    "commonFlags": {
        "format": {
            "description": {
                "en": "Output format (default: tsv)"
            },
            "value": "csv|tsv",
            "required": false
        },
        "label": {
            "description": {
                "en": "Item label (required: label or icon)"
            },
            "value": {
                "en": "<label>"
            },
            "required": false
        },
        "icon": {
            "description": {
                "en": "Item icon, from Lucide's icon set (required: label or icon)"
            },
            "value": {
                "en": "<iconName>"
            },
            "required": false
        },
        "item": {
            "description": {
                "en": "Item ID"
            },
            "value": {
                "en": "<itemId>"
            },
            "required": true
        },
        "pos": {
            "description": {
                "en": "Item position in toolbar (default: end of toolbar)"
            },
            "value": {
                "en": "<n>"
            },
            "required": false
        },
        "to": {
            "description": {
                "en": "Toolbar name or ID to add item to"
            },
            "value": {
                "en": "<toolbarNameOrId>"
            },
            "required": true
        },
        "tooltip": {
            "description": {
                "en": "Item tooltip"
            },
            "value": {
                "en": "<tooltip>"
            },
            "required": false
        },
        "verbose": {
            "description": {
                "en": "Include additional details in output"
            },
            "required": false
        }
    },
    "commands": {
        "note-toolbar": {
            "category": "help",
            "description": {
                "en": "Display Note Toolbar CLI help"
            },
            "docs": "Lists all Note Toolbar CLI actions."
        },
        "note-toolbar:add-break": {
            "category": "items-add",
            "description": {
                "en": "Add a line break to a toolbar"
            },
            "docs": "Adds a [break](https://github.com/chrisgurney/obsidian-note-toolbar/wiki/Creating-toolbar-items#toolbar-layout) to a toolbar.",
            "flags": {
                "$before": ["to", "pos"]
            }
        },
        "note-toolbar:add-command": {
            "category": "items-add",
            "description": {
                "en": "Add a command item to a toolbar"
            },
            "docs": "Adds a [command item](https://github.com/chrisgurney/obsidian-note-toolbar/wiki/Command-items) to a toolbar.",
            "examples": "# Add a bold toggle to an existing toolbar\nnote-toolbar:add-command to=\"Formatting Tools\" icon=bold command=\"editor:toggle-bold\"",
            "flags": {
                "$before": ["to", "label", "icon"],
                "$after": ["tooltip", "pos"],
                "command": {
                    "description": {
                        "en": "Obsidian command ID (e.g. editor:toggle-bold)"
                    },
                    "value": {
                        "en": "<commandId>"
                    },
                    "required": true
                },
                "focus": {
                    "description": {
                        "en": "Focus the editor after executing the command (default: false)"
                    },
                    "required": false
                },
                "target": {
                    "description": {
                        "en": "Where to run command"
                    },
                    "value": "split|tab",
                    "required": false
                }
            }
        },
        "note-toolbar:add-file": {
            "category": "items-add",
            "description": {
                "en": "Add a file item to a toolbar"
            },
            "docs": "Adds a [file item](https://github.com/chrisgurney/obsidian-note-toolbar/wiki/File-items) to a toolbar.",
            "flags": {
                "$before": ["to", "label", "icon"],
                "$after": ["tooltip", "pos"],
                "file": {
                    "description": {
                        "en": "File to link to (required: file or path)"
                    },
                    "docs": "Resolves the file using the same link resolution as wikilinks, matching by file name without requiring the full path or extension.",
                    "value": {
                        "en": "<name>"
                    },
                    "required": false
                },
                "path": {
                    "description": {
                        "en": "Path of file to link to (required: file or path)"
                    },
                    "docs": "Requires the exact path from the vault root, e.g. folder/file.md",
                    "value": {
                        "en": "<path>"
                    },
                    "required": false
                },
                "target": {
                    "description": {
                        "en": "Where to open the file"
                    },
                    "value": "modal|split|tab|window",
                    "required": false
                }
            }
        },
        "note-toolbar:add-group": {
            "category": "items-add",
            "description": {
                "en": "Add an item group to a toolbar"
            },
            "docs": "Adds an [item group](https://github.com/chrisgurney/obsidian-note-toolbar/wiki/Item-groups) to a toolbar.",
            "flags": {
                "$before": ["to"],
                "$after": ["pos"],
                "toolbar": {
                    "description": {
                        "en": "Toolbar to add as a group"
                    },
                    "value": {
                        "en": "<toolbarNameOrId>"
                    },
                    "required": true
                }
            }
        },
        "note-toolbar:add-js": {
            "category": "items-add",
            "description": {
                "en": "Add a JavaScript item to a toolbar"
            },
            "docs": "Adds a [JavaScript item](https://github.com/chrisgurney/obsidian-note-toolbar/wiki/JavaScript) to a toolbar.",
            "flags": {
                "$before": ["to", "label", "icon"],
                "$after": ["tooltip", "pos"],
                "code": {
                    "description": {
                        "en": "JavaScript code to execute (required: code, file, or path)"
                    },
                    "value": {
                        "en": "<code>"
                    },
                    "required": false
                },
                "file": {
                    "description": {
                        "en": "Filename to execute (required: code, file, or path)"
                    },
                    "docs": "Resolves the file using the same link resolution as wikilinks, matching by file name without requiring the full path or extension.",
                    "value": {
                        "en": "<name>"
                    },
                    "required": false
                },
                "path": {
                    "description": {
                        "en": "Filename with path to execute (required: code, file, or path)"
                    },
                    "docs": "Requires the exact path from the vault root, e.g. folder/script.js",
                    "value": {
                        "en": "<path>"
                    },
                    "required": false
                },
                "args": {
                    "description": {
                        "en": "Comma-separated 'name: value' format, with string values in quotes"
                    },
                    "value": {
                        "en": "<args>"
                    },
                    "required": false
                }
            }
        },
        "note-toolbar:add-menu": {
            "category": "items-add",
            "description": {
                "en": "Add an item menu to a toolbar"
            },
            "docs": "Adds an [item menu](https://github.com/chrisgurney/obsidian-note-toolbar/wiki/Item-Menus) to a toolbar.",
            "flags": {
                "$before": ["to", "label", "icon"],
                "$after": ["tooltip", "pos"],
                "toolbar": {
                    "description": {
                        "en": "Toolbar to add as a menu"
                    },
                    "value": {
                        "en": "<toolbarNameOrId>"
                    },
                    "required": true
                }
            }
        },
        "note-toolbar:add-sep": {
            "category": "items-add",
            "description": {
                "en": "Add a separator to a toolbar"
            },
            "docs": "Adds a [separator](https://github.com/chrisgurney/obsidian-note-toolbar/wiki/Creating-toolbar-items#toolbar-layout) to a toolbar.",
            "flags": {
                "$before": ["to", "pos"]
            }
        },
        "note-toolbar:add-spread": {
            "category": "items-add",
            "description": {
                "en": "Add a spreader to a toolbar"
            },
            "docs": "Adds a [spreader](https://github.com/chrisgurney/obsidian-note-toolbar/wiki/Creating-toolbar-items#toolbar-layout) to a toolbar.",
            "flags": {
                "$before": ["to", "pos"]
            }
        },
        "note-toolbar:add-uri": {
            "category": "items-add",
            "description": {
                "en": "Add a URI item to a toolbar"
            },
            "docs": "Adds a [URI item](https://github.com/chrisgurney/obsidian-note-toolbar/wiki/URI-items) to a toolbar.",
            "flags": {
                "$before": ["to", "label", "icon"],
                "$after": ["tooltip", "pos"],
                "uri": {
                    "description": {
                        "en": "Website, URI, or note title"
                    },
                    "value": {
                        "en": "<link>"
                    },
                    "required": true
                },
                "target": {
                    "description": {
                        "en": "Where to open the URI"
                    },
                    "value": "modal|split|tab|window",
                    "required": false
                }
            }
        },
        "note-toolbar:copy": {
            "category": "items-copy",
            "description": {
                "en": "Copy an item to a toolbar"
            },
            "docs": "Copies an item to a toolbar.",
            "flags": {
                "$before": ["to", "item"],
                "$after": ["pos"]
            }
        },
        "note-toolbar:gallery": {
            "category": "items",
            "description": {
                "en": "List items in the Gallery"
            },
            "docs": "Lists items in the [Note Toolbar Gallery](https://github.com/chrisgurney/obsidian-note-toolbar/wiki/Gallery). Copy them to toolbars using the `note-toolbar:copy` command."
        },
        "note-toolbar:help": {
            "category": "help",
            "description": {
                "en": "Display Note Toolbar CLI help"
            },
            "docs": "Lists all Note Toolbar CLI actions."
        },
        "note-toolbar:items": {
            "category": "items",
            "description": {
                "en": "List toolbar items"
            },
            "docs": "Lists all toolbar items, except empty items (no label or tooltip) by default.",
            "flags": {
                "$after": ["verbose", "format"],
                "toolbar": {
                    "description": {
                        "en": "Toolbar to list items for"
                    },
                    "value": {
                        "en": "<nameOrId>"
                    },
                    "required": false
                },
                "empty": {
                    "description": {
                        "en": "Include empty items in output"
                    },
                    "required": false
                },
                "total": {
                    "description": {
                        "en": "Returns item count"
                    },
                    "required": false
                }
            }
        },
        "note-toolbar:move": {
            "category": "items-copy",
            "description": {
                "en": "Move an item to a toolbar"
            },
            "docs": "Moves an item to a toolbar.",
            "flags": {
                "$before": ["to", "item"],
                "$after": ["pos"]
            }
        },
        "note-toolbar:new": {
            "category": "toolbars",
            "description": {
                "en": "Create a new toolbar"
            },
            "docs": "Creates a new toolbar.",
            "flags": {
                "name": {
                    "description": {
                        "en": "Toolbar name"
                    },
                    "value": {
                        "en": "<name>"
                    },
                    "required": false
                }
            }
        },
        "note-toolbar:rules": {
            "category": "rules",
            "description": {
                "en": "List mapping rules"
            },
            "docs": "Lists toolbar [folder mappings](https://github.com/chrisgurney/obsidian-note-toolbar/wiki/Defining-where-to-show-toolbars).",
            "flags": {
                "$after": ["format"]
            }
        },
        "note-toolbar:settings": {
            "category": "settings",
            "description": {
                "en": "Open Note Toolbar settings in Obsidian"
            },
            "docs": "Opens settings in Obsidian for the provided item or toolbar. Opens main settings by default.",
            "flags": {
                "item": {
                    "description": {
                        "en": "ID of item to open settings for"
                    },
                    "value": {
                        "en": "<itemId>"
                    },
                    "required": false
                },
                "toolbar": {
                    "description": {
                        "en": "ID of toolbar to open settings for"
                    },
                    "value": {
                        "en": "<nameOrId>"
                    },
                    "required": false
                }
            }
        },        
        "note-toolbar:toolbars": {
            "category": "toolbars",
            "description": {
                "en": "Lists toolbars"
            },
            "docs": "Lists all toolbars.",
            "flags": {
                "$after": ["verbose", "format"]
            }
        },
        "note-toolbar:use": {
            "category": "items",
            "description": {
                "en": "Uses the item"
            },
            "docs": "Uses an item. Defaults to using the item within the active file.",
            "flags": {
                "item": {
                    "description": {
                        "en": "ID of item to use"
                    },
                    "value": {
                        "en": "<itemId>"
                    },
                    "required": true
                },
                "file": {
                    "description": {
                        "en": "File to use the item in"
                    },
                    "docs": "Resolves the file using the same link resolution as wikilinks, matching by file name without requiring the full path or extension.",
                    "value": {
                        "en": "<name>"
                    },
                    "required": false
                },
                "path": {
                    "description": {
                        "en": "Path of file to use the item in"
                    },
                    "docs": "Requires the exact path from the vault root, e.g. folder/file.md",
                    "value": {
                        "en": "<path>"
                    },
                    "required": false
                }
            }
        }
    }
}