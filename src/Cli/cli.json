{
    "id": "note-toolbar",
    "description": {
        "en": "Display Note Toolbar CLI help"
    },
    "heading": {
        "en": "Note Toolbar CLI actions:"
    },
    "commonFlags": {
        "toolbar": {
            "description": {
                "en": "Toolbar name or ID to add item to"
            },
            "type": "string",
            "value": {
                "en": "<nameOrId>"
            },
            "required": true
        },
        "label": {
            "description": {
                "en": "Item label (required if icon is not provided)"
            },
            "type": "string",
            "value": {
                "en": "<label>"
            },
            "required": false
        },
        "icon": {
            "description": {
                "en": "Item icon, from Lucide's icon set (required if label is not provided)"
            },
            "type": "string",
            "value": {
                "en": "<iconName>"
            },
            "required": false
        },
        "tooltip": {
            "description": {
                "en": "Item tooltip"
            },
            "type": "string",
            "value": {
                "en": "<tooltip>"
            },
            "required": false
        },
        "pos": {
            "description": {
                "en": "Item position in toolbar; default = end"
            },
            "type": "string",
            "value": {
                "en": "<n>"
            },
            "required": false
        }
    },
    "actions": [
        {
            "id": "note-toolbar:add-break",
            "description": {
                "en": "Add a line break to a toolbar"
            },
            "flags": {
                "$before": ["toolbar", "pos"]
            }
        },
        {
            "id": "note-toolbar:add-command",
            "description": {
                "en": "Add command item to a toolbar"
            },
            "flags": {
                "$before": ["toolbar", "label", "icon"],
                "$after": ["tooltip", "pos"],
                "command": {
                    "description": {
                        "en": "Obsidian command ID (e.g. editor:toggle-bold)"
                    },
                    "type": "string",
                    "value": {
                        "en": "<commandId>"
                    },
                    "required": true
                }
            }
        },
        {
            "id": "note-toolbar:add-js",
            "description": {
                "en": "Add JavaScript item to a toolbar"
            },
            "flags": {
                "$before": ["toolbar", "label", "icon"],
                "$after": ["tooltip", "pos"],
                "code": {
                    "description": {
                        "en": "JavaScript code to execute (required if file is not provided)"
                    },
                    "type": "string",
                    "value": {
                        "en": "<code>"
                    },
                    "required": false
                },
                "file": {
                    "description": {
                        "en": "Filename to execute (file or path required if code is not provided)"
                    },
                    "notes": "Resolves the file using the same link resolution as wikilinks, matching by file name without requiring the full path or extension.",
                    "type": "string",
                    "value": {
                        "en": "<file>"
                    },
                    "required": false
                },
                "path": {
                    "description": {
                        "en": "Filename with path to execute (file or path required if code is not provided)."
                    },
                    "notes": "Requires the exact path from the vault root, e.g. folder/script.js",
                    "type": "string",
                    "value": {
                        "en": "<path>"
                    },
                    "required": false
                },
                "args": {
                    "description": {
                        "en": "Comma-separated 'name: value' format, with string values in quotes"
                    },
                    "type": "string",
                    "value": {
                        "en": "<args>"
                    },
                    "required": false
                }
            }
        },
        {
            "id": "note-toolbar:add-sep",
            "description": {
                "en": "Add a separator to a toolbar"
            },
            "flags": {
                "$before": ["toolbar", "pos"]
            }
        },
        {
            "id": "note-toolbar:add-spread",
            "description": {
                "en": "Add a spreader to a toolbar"
            },
            "flags": {
                "$before": ["toolbar", "pos"]
            }
        }
    ]
}