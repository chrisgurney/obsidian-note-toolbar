{
    "id": "note-toolbar",
    "description": {
        "en": "Displays Note Toolbar CLI help"
    },
    "heading": {
        "en": "Note Toolbar CLI actions:"
    },
    "commonFlags": {
        "toolbar": {
            "description": {
                "en": "Name or ID of toolbar to add the item to"
            },
            "type": "string",
            "value": {
                "en": "<nameOrId>"
            },
            "required": true
        },
        "label": {
            "description": {
                "en": "Display label for the item (required if icon is not provided)"
            },
            "type": "string",
            "value": {
                "en": "<label>"
            },
            "required": false
        },
        "icon": {
            "description": {
                "en": "Icon for the item, from Lucide's icon set (required if label is not provided)"
            },
            "type": "string",
            "value": {
                "en": "<iconName>"
            },
            "required": false
        },
        "tooltip": {
            "description": {
                "en": "Tooltip text."
            },
            "type": "string",
            "value": {
                "en": "<tooltip>"
            },
            "required": false
        },
        "pos": {
            "description": {
                "en": "Position in the toolbar to put the item; default = end"
            },
            "type": "string",
            "value": {
                "en": "<n>"
            },
            "required": false
        }
    },
    "actions": [
        {
            "id": "note-toolbar:add-command",
            "description": {
                "en": "Adds a command item to the specified toolbar"
            },
            "flags": {
                "$before": ["toolbar"],
                "$after": ["label", "icon", "tooltip", "pos"],
                "command": {
                    "description": {
                        "en": "Obsidian command ID (eg: editor:toggle-bold)"
                    },
                    "type": "string",
                    "value": {
                        "en": "<commandId>"
                    },
                    "required": true
                }
            }
        },
        {
            "id": "note-toolbar:add-js",
            "description": {
                "en": "Adds a JavaScript item to the specified toolbar"
            },
            "flags": {
                "$before": ["toolbar"],
                "$after": ["label", "icon", "tooltip", "pos"]
            }
        }
    ]
}