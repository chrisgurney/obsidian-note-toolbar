{
    "id": "note-toolbar",
    "description": {
        "en": "Displays Note Toolbar CLI help."
    },
    "heading": {
        "en": "Note Toolbar CLI actions:"
    },
    "commonFlags": {
        "toolbar": {
            "description": {
                "en": "Name or ID of the toolbar to add the item to."
            },
            "type": "string",
            "value": {
                "en": "<nameOrId>"
            },
            "required": true
        },
        "label": {
            "description": {
                "en": "Display label for the item. Required if icon is not provided."
            },
            "type": "string",
            "value": {
                "en": "<label>"
            },
            "required": false
        },
        "icon": {
            "description": {
                "en": "Icon for the item, from Lucide's icon set. Required if label is not provided."
            },
            "type": "string",
            "value": {
                "en": "<iconName>"
            },
            "required": false
        },
        "tooltip": {
            "description": {
                "en": "Tooltip text."
            },
            "type": "string",
            "value": {
                "en": "<tooltip>"
            },
            "required": false
        }
    },
    "actions": [
        {
            "id": "note-toolbar:add-command",
            "description": {
                "en": "Adds a command item to the specified toolbar."
            },
            "flags": {
                "$before": ["toolbar"],
                "$after": ["label", "icon", "tooltip"],
                "command": {
                    "description": {
                        "en": "Obsidian command ID (e.g. editor:toggle-bold)"
                    },
                    "type": "string",
                    "value": {
                        "en": "<commandId>"
                    },
                    "required": true
                }
            }
        },
        {
            "id": "note-toolbar:add-javascript",
            "description": {
                "en": "Adds a JavaScript item to the specified toolbar."
            },
            "flags": {
                "toolbar": {
                    "description": {
                        "en": "Name or ID of the toolbar to add the item to"
                    },
                    "type": "string",
                    "value": {
                        "en": "<nameOrId>"
                    },
                    "required": true
                }
            }
        }
    ]
}