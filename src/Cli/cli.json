{
    "id": "note-toolbar",
    "description": {
        "en": "Display Note Toolbar CLI help"
    },
    "heading": {
        "en": "Note Toolbar CLI actions:"
    },
    "docs": "Lists all Note Toolbar CLI actions.",
    "categories": [
        {
            "id": "help",
            "heading": "Help"
        },
        {
            "id": "items",
            "heading": "Items"
        },
        {
            "id": "items-add",
            "heading": "Items (Adding)",
            "docs": "Add items to toolbars."
        },
        {
            "id": "toolbars",
            "heading": "Toolbars"
        }
    ],
    "commonFlags": {
        "format": {
            "description": {
                "en": "Output format (default: tsv)"
            },
            "type": "string",
            "value": {
                "en": "tsv|csv"
            },
            "required": false
        },
        "label": {
            "description": {
                "en": "(required if icon not provided) Item label"
            },
            "type": "string",
            "value": {
                "en": "<label>"
            },
            "required": false
        },
        "icon": {
            "description": {
                "en": "(required if label not provided) Item icon, from Lucide's icon set"
            },
            "type": "string",
            "value": {
                "en": "<iconName>"
            },
            "required": false
        },
        "pos": {
            "description": {
                "en": "Item position in toolbar (default: end)"
            },
            "type": "string",
            "value": {
                "en": "<n>"
            },
            "required": false
        },
        "toolbar": {
            "description": {
                "en": "Toolbar name or ID to add item to"
            },
            "type": "string",
            "value": {
                "en": "<nameOrId>"
            },
            "required": true
        },
        "tooltip": {
            "description": {
                "en": "Item tooltip"
            },
            "type": "string",
            "value": {
                "en": "<tooltip>"
            },
            "required": false
        },
        "verbose": {
            "description": {
                "en": "Include additional details in output"
            },
            "type": "boolean",
            "required": false
        }
    },
    "actions": [
        {
            "id": "note-toolbar:add-break",
            "category": "items-add",
            "description": {
                "en": "Add a line break to a toolbar"
            },
            "docs": "Adds a [break](https://github.com/chrisgurney/obsidian-note-toolbar/wiki/Creating-toolbar-items#toolbar-layout) to a toolbar.",
            "flags": {
                "$before": ["toolbar", "pos"]
            }
        },
        {
            "id": "note-toolbar:add-command",
            "category": "items-add",
            "description": {
                "en": "Add command item to a toolbar"
            },
            "docs": "Adds a [command item](https://github.com/chrisgurney/obsidian-note-toolbar/wiki/Command-items) to a toolbar.",
            "examples": "# Add a bold toggle to an existing toolbar\nnote-toolbar:add-command toolbar=\"Formatting Tools\" icon=bold command=\"editor:toggle-bold\"",
            "flags": {
                "$before": ["toolbar", "label", "icon"],
                "$after": ["tooltip", "pos"],
                "command": {
                    "description": {
                        "en": "Obsidian command ID (e.g. editor:toggle-bold)"
                    },
                    "type": "string",
                    "value": {
                        "en": "<commandId>"
                    },
                    "required": true
                },
                "focus": {
                    "description": {
                        "en": "Focus the editor after executing the command (default: false)"
                    },
                    "type": "boolean",
                    "required": false
                }
            }
        },
        {
            "id": "note-toolbar:add-js",
            "category": "items-add",
            "description": {
                "en": "Add JavaScript item to a toolbar"
            },
            "docs": "Adds a [JavaScript item](https://github.com/chrisgurney/obsidian-note-toolbar/wiki/JavaScript) to a toolbar.",
            "flags": {
                "$before": ["toolbar", "label", "icon"],
                "$after": ["tooltip", "pos"],
                "code": {
                    "description": {
                        "en": "(required if file|path not provided) JavaScript code to execute"
                    },
                    "type": "string",
                    "value": {
                        "en": "<code>"
                    },
                    "required": false
                },
                "file": {
                    "description": {
                        "en": "(required if code|path not provided) Filename to execute"
                    },
                    "docs": "Resolves the file using the same link resolution as wikilinks, matching by file name without requiring the full path or extension.",
                    "type": "string",
                    "value": {
                        "en": "<name>"
                    },
                    "required": false
                },
                "path": {
                    "description": {
                        "en": "(required if file|code not provided) Filename with path to execute"
                    },
                    "docs": "Requires the exact path from the vault root, e.g. folder/script.js",
                    "type": "string",
                    "value": {
                        "en": "<path>"
                    },
                    "required": false
                },
                "args": {
                    "description": {
                        "en": "Comma-separated 'name: value' format, with string values in quotes"
                    },
                    "type": "string",
                    "value": {
                        "en": "<args>"
                    },
                    "required": false
                }
            }
        },
        {
            "id": "note-toolbar:add-sep",
            "category": "items-add",
            "description": {
                "en": "Add a separator to a toolbar"
            },
            "docs": "Adds a [separator](https://github.com/chrisgurney/obsidian-note-toolbar/wiki/Creating-toolbar-items#toolbar-layout) to a toolbar.",
            "flags": {
                "$before": ["toolbar", "pos"]
            }
        },
        {
            "id": "note-toolbar:add-spread",
            "category": "items-add",
            "description": {
                "en": "Add a spreader to a toolbar"
            },
            "docs": "Adds a [spreader](https://github.com/chrisgurney/obsidian-note-toolbar/wiki/Creating-toolbar-items#toolbar-layout) to a toolbar.",
            "flags": {
                "$before": ["toolbar", "pos"]
            }
        },
        {
            "id": "note-toolbar:add-toolbar",
            "category": "toolbars",
            "description": {
                "en": "Create a new toolbar"
            },
            "docs": "Creates a new toolbar.",
            "flags": {
                "name": {
                    "description": {
                        "en": "Toolbar name"
                    },
                    "type": "string",
                    "value": {
                        "en": "<name>"
                    },
                    "required": false
                }
            }
        },
        {
            "id": "note-toolbar:help",
            "category": "help",
            "description": {
                "en": "Opens Note Toolbar's CLI user guide in a browser"
            },
            "docs": "Opens Note Toolbar's CLI user guide (this page) in a browser."
        },
        {
            "id": "note-toolbar:items",
            "category": "items",
            "description": {
                "en": "Lists toolbar items"
            },
            "docs": "Lists all toolbar items, except empty items (no label or tooltip) by default.",
            "flags": {
                "$after": ["verbose", "format"],
                "empty": {
                    "description": {
                        "en": "Include empty items in output"
                    },
                    "type": "boolean",
                    "required": false
                }
            }
        },
        {
            "id": "note-toolbar:toolbars",
            "category": "toolbars",
            "description": {
                "en": "Lists toolbars"
            },
            "docs": "Lists all toolbars.",
            "flags": {
                "$after": ["verbose", "format"]
            }
        }
    ]
}