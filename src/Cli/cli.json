{
    "id": "note-toolbar",
    "description": {
        "en": "Commands for managing Note Toolbars."
    },
    "actions": [
        {
            "id": "note-toolbar:add-command",
            "description": {
                "en": "Adds a command item to the specified toolbar."
            },
            "flags": {
                "toolbar": {
                    "description": {
                        "en": "Name or ID of the toolbar to add the item to"
                    },
                    "type": "string",
                    "value": {
                        "en": "<nameOrId>"
                    },
                    "required": true
                },
                "command": {
                    "description": {
                        "en": "Obsidian command ID (e.g. editor:toggle-bold)"
                    },
                    "type": "string",
                    "value": {
                        "en": "<commandId>"
                    },
                    "required": true
                },
                "label": {
                    "description": {
                        "en": "Display label for the item."
                    },
                    "type": "string",
                    "required": false
                },
                "icon": {
                    "description": {
                        "en": "Lucide icon name."
                    },
                    "type": "string",
                    "required": false
                },
                "tooltip": {
                    "description": {
                        "en": "Tooltip text. Defaults to label if omitted."
                    },
                    "type": "string",
                    "required": false
                }
            }
        },
        {
            "id": "note-toolbar:add-javascript",
            "description": {
                "en": "Adds a JavaScript item to the specified toolbar."
            },
            "flags": {
                "toolbar": {
                    "description": {
                        "en": "Name or ID of the toolbar to add the item to"
                    },
                    "type": "string",
                    "value": {
                        "en": "<nameOrId>"
                    },
                    "required": true
                }
            }
        }
    ]
}